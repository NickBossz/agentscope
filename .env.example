# Runtime
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# PostgreSQL
POSTGRES_DB=agentscope
POSTGRES_USER=agentscope
POSTGRES_PASSWORD=agentscope
DATABASE_URL=postgresql://agentscope:agentscope@localhost:5432/agentscope

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
# Generate at least 32 random bytes for production.
AUTH_SECRET=replace-with-a-long-random-secret
SESSION_TTL_SECONDS=604800

# Encryption reserved for sensitive trace data.
TRACE_ENCRYPTION_KEY=development-trace-encryption-key-change-me

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agentscope
